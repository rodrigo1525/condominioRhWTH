# ===========================================
# Condominio RM - Variables de entorno
# ===========================================
# Copia este archivo a .env y completa los valores.
# .env no debe subirse a Git (ya está en .gitignore).
# ===========================================
#
# Para que "Crear usuario" y "Link respaldo" funcionen (error "not found"):
# 1. Rellena aquí el PROJECT_ID y el resto de la config de tu proyecto Firebase.
# 2. En la raíz del proyecto ejecuta: firebase use <tu-project-id>
# 3. Despliega las Cloud Functions: firebase deploy --only functions
#    (o desde /functions: npm run deploy)
# 4. La región por defecto es us-central1; si despliegas en otra, define
#    EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION con esa región.
#
# ===========================================

# --- Firebase Auth & Firestore ---
# Configuración en https://console.firebase.google.com → Tu proyecto → Configuración del proyecto
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Región de Cloud Functions (debe coincidir con el despliegue; por defecto us-central1)
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# --- Azure Read OCR ---
# Computer Vision Read API (https://portal.azure.com)
EXPO_PUBLIC_AZURE_OCR_ENDPOINT=https://tu-recurso.cognitiveservices.azure.com/
EXPO_PUBLIC_AZURE_OCR_API_KEY=
