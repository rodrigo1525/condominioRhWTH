rules_version = '2';
// Despliegue: firebase deploy --only storage
// Las fotos de lecturas se guardan en readings/{userId}/{archivo}
service firebase.storage {
  match /b/{bucket}/o {
    match /readings/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
